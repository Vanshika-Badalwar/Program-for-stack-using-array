#include <iostream>
using namespace std;

#define MAX 5

class Stack
{
    int arr[MAX];
    int top;

public:
    Stack()
    {
        top = -1;
    }

    bool isEmpty()
    {
        return (top == -1);
    }

    bool isFull()
    {
        return (top == MAX - 1);
    }

    // Push Operation
    void push(int value)
    {
        if (isFull())
        {
            cout << "Stack overflow! cannot insert " << value << endl;
        }
        else
        {
            arr[++top] = value;
            cout << value << " pushed into stack." << endl;
        }
    }

    // Pop Operation
    void pop()
    {
        if (isEmpty())
        {
            cout << "Stack underflow! cannot delete." << endl;
        }
        else
        {
            cout << arr[top--] << " popped from stack." << endl;
        }
    }

    // Peek Operation
    void peek()
    {
        if (isEmpty())
        {
            cout << "Stack is empty." << endl;
        }
        else
        {
            cout << "Top element is : " << arr[top] << endl;
        }
    }
};

int main()
{
    Stack s;

    s.push(10);
    s.push(20);
    s.push(30);

    s.peek();
    s.pop();
    s.peek();

    return 0;
}
